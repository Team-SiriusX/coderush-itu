generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// Better Auth required models (keep as-is)
model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  emailVerified  Boolean   @default(false)
  image          String?
  role           UserRole  @default(CAPTAIN)
  assignedShipId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sessions       Session[]
  accounts       Account[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Fleet models
model RestrictedZone {
  id        String   @id @default(cuid())
  name      String
  geometry  Json
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Alert {
  id           String        @id @default(cuid())
  type         AlertType
  severity     AlertSeverity
  shipId       String
  message      String
  acknowledged Boolean       @default(false)
  resolved     Boolean       @default(false)
  metadata     Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Directive {
  id        String             @id @default(cuid())
  shipId    String
  type      DirectiveType
  payload   Json
  response  DirectiveResponse?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model DistressMessage {
  id         String   @id @default(cuid())
  shipId     String
  rawMessage String
  extraction Json
  createdAt  DateTime @default(now())
}

model PlaybackFrame {
  id        String   @id @default(cuid())
  timestamp DateTime
  ships     Json
  alerts    Json
  zones     Json
  createdAt DateTime @default(now())
}

enum UserRole {
  COMMAND
  CAPTAIN
}

enum AlertType {
  GEOFENCE_BREACH
  PROXIMITY_WARNING
  DISTRESS_SIGNAL
  LOW_FUEL
  OUT_OF_FUEL
  ROUTE_BLOCKED
  INSUFFICIENT_FUEL
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DirectiveType {
  REROUTE
  HOLD
  DIVERT
  RETURN_TO_PORT
}

enum DirectiveResponse {
  ACCEPT
  ESCALATE_DISTRESS
}
